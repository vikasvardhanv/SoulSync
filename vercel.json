{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "backend/src/server.js"
    }
  ],
  "installCommand": "npm install --workspace=backend",
  "buildCommand": "npm run build --workspace=backend"
}